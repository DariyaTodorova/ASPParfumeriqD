@model ASPParfumeriq.Models.Product

@{
    ViewData["Title"] = "Детайли";
}

<div class="details-container">

    <div class="details-image">
        <img src="@Model.PhotoUrl" alt="@Model.Name" />
    </div>

    <div class="details-info">

        <h1>@Model.Name</h1>

        <div class="details-price">
            €@Model.Price
        </div>

        <p class="details-description">
            @Model.Description
        </p>

        <div class="details-meta">

            <p>
                Количество: @Model.Quantity
            </p>

            @if (Model.Category != null)
            {
                <p>
                    Категория: @Model.Category.Name
                </p>
            }

            @if (Model.TypeParfume != null)
            {
                <p>
                    Тип: @Model.TypeParfume.Name
                </p>
            }

        </div>

        <div class="details-buttons">

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-controller="Orders"
                   asp-action="Create"
                   class="btn btn-primary">
                    Поръчай
                </a>
            }

            <a asp-action="Index"
               class="btn btn-outline-light">
                Назад
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-warning">
                    Edit
                </a>
            }

        </div>

    </div>

</div>