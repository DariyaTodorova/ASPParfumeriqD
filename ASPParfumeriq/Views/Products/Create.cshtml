@model ASPParfumeriq.Models.Product

@{
    ViewData["Title"] = "Добави продукт";
}

<div class="form-page">

    <div class="form-card">

        <h1>Добави продукт</h1>
        <p>Въведи данните за новия парфюм.</p>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name">Име</label>
                <input asp-for="Name" class="form-control" placeholder="Пример: Dior Sauvage" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId">Категория</label>
                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Quantity">Количество</label>
                <input asp-for="Quantity" class="form-control" placeholder="Пример: 10" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TypeParfumeId">Тип парфюм</label>
                <select asp-for="TypeParfumeId" class="form-control" asp-items="ViewBag.TypeParfumeId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PhotoUrl">Снимка</label>
                <input asp-for="PhotoUrl" class="form-control" placeholder="/images/dior.jpg" />
                <span asp-validation-for="PhotoUrl" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price">Цена в евро</label>
                <input asp-for="Price" class="form-control" placeholder="Пример: 89.99" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Кратко описание на аромата..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-buttons">
                <button type="submit" class="btn btn-primary">
                    Запази
                </button>

                <a asp-action="Index" class="btn btn-outline-light">
                    Назад
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}